---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Manage Gallery - Asterion Safari">
  <!-- Loading spinner -->
  <div id="loading" class="min-h-screen flex items-center justify-center bg-[#f8f9fa]">
    <div class="w-10 h-10 border-4 border-orange-200 border-t-orange-500 rounded-full animate-spin"></div>
  </div>

  <!-- Gallery management content -->
  <div id="gallery-page" class="hidden min-h-screen bg-[#f8f9fa]">
    <!-- Header -->
    <header class="bg-white shadow-sm border-b border-gray-100">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/">
          <img src="/photo/logo.svg" alt="Asterion Safari" class="h-10" />
        </a>
        <div class="flex items-center gap-4">
          <a href="/dashboard" class="text-sm text-gray-600 hover:text-orange-500 transition-colors">&larr; Back to Dashboard</a>
          <button
            id="sign-out-btn"
            class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-6 py-2 rounded-full text-sm transition-colors cursor-pointer"
          >
            Sign Out
          </button>
        </div>
      </div>
    </header>

    <!-- Main -->
    <main class="max-w-6xl mx-auto px-6 py-12">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Gallery</h1>
        <label class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-6 py-2 rounded-full text-sm transition-colors cursor-pointer">
          + Upload Images
          <input type="file" accept="image/*" multiple id="upload-input" class="hidden" />
        </label>
      </div>

      <!-- Upload status -->
      <div id="upload-status" class="hidden mb-6 bg-orange-50 border border-orange-200 rounded-xl p-4">
        <p id="upload-status-text" class="text-sm text-orange-700"></p>
        <div class="w-full bg-orange-100 rounded-full h-2 mt-2">
          <div id="upload-progress" class="bg-orange-500 h-2 rounded-full transition-all" style="width: 0%"></div>
        </div>
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-16">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <p class="text-gray-500">No gallery images yet. Upload some!</p>
      </div>

      <!-- Gallery grid -->
      <div id="gallery-grid" class="hidden grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4"></div>
    </main>
  </div>
</Layout>

<script>
  import { signOut } from "firebase/auth";
  import { collection, doc, setDoc, deleteDoc, onSnapshot, orderBy, query, serverTimestamp, writeBatch } from "firebase/firestore";
  import { requireAuth } from "../lib/auth-guard";
  import { auth, db } from "../lib/firebase";
  import { uploadImage, deleteImage } from "../lib/upload-image";

  const user = await requireAuth();

  document.getElementById("loading")!.classList.add("hidden");
  document.getElementById("gallery-page")!.classList.remove("hidden");

  document.getElementById("sign-out-btn")!.addEventListener("click", async () => {
    await signOut(auth);
    window.location.href = "/login";
  });

  type GalleryImage = {
    id: string;
    url: string;
    alt: string;
    order: number;
  };

  let allImages: GalleryImage[] = [];

  const galleryGrid = document.getElementById("gallery-grid")!;
  const emptyState = document.getElementById("empty-state")!;
  const uploadStatus = document.getElementById("upload-status")!;
  const uploadStatusText = document.getElementById("upload-status-text")!;
  const uploadProgress = document.getElementById("upload-progress")!;

  function renderGallery(images: GalleryImage[]) {
    galleryGrid.innerHTML = "";
    if (images.length === 0) {
      galleryGrid.classList.add("hidden");
      emptyState.classList.remove("hidden");
      return;
    }
    emptyState.classList.add("hidden");
    galleryGrid.classList.remove("hidden");

    images.forEach((img, index) => {
      const card = document.createElement("div");
      card.className = "relative group bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden";
      card.innerHTML = `
        <img src="${escapeAttr(img.url)}" alt="${escapeAttr(img.alt)}" class="w-full h-40 object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-colors flex items-center justify-center opacity-0 group-hover:opacity-100">
          <div class="flex gap-2">
            ${index > 0 ? `<button class="move-up-btn bg-white/90 hover:bg-white text-gray-700 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold" data-id="${img.id}" title="Move up">&uarr;</button>` : ""}
            ${index < images.length - 1 ? `<button class="move-down-btn bg-white/90 hover:bg-white text-gray-700 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold" data-id="${img.id}" title="Move down">&darr;</button>` : ""}
            <button class="delete-btn bg-red-500/90 hover:bg-red-600 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold" data-id="${img.id}" data-url="${escapeAttr(img.url)}" title="Delete">&times;</button>
          </div>
        </div>
        <div class="p-2">
          <input type="text" value="${escapeAttr(img.alt)}" placeholder="Alt text" class="alt-input w-full text-xs border border-gray-200 rounded px-2 py-1 focus:outline-none focus:ring-1 focus:ring-orange-400" data-id="${img.id}" />
        </div>
      `;
      galleryGrid.appendChild(card);
    });

    // Move up
    galleryGrid.querySelectorAll(".move-up-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = (btn as HTMLElement).dataset.id!;
        const idx = allImages.findIndex((i) => i.id === id);
        if (idx <= 0) return;
        await swapOrder(allImages[idx], allImages[idx - 1]);
      });
    });

    // Move down
    galleryGrid.querySelectorAll(".move-down-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = (btn as HTMLElement).dataset.id!;
        const idx = allImages.findIndex((i) => i.id === id);
        if (idx < 0 || idx >= allImages.length - 1) return;
        await swapOrder(allImages[idx], allImages[idx + 1]);
      });
    });

    // Delete
    galleryGrid.querySelectorAll(".delete-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = (btn as HTMLElement).dataset.id!;
        const url = (btn as HTMLElement).dataset.url!;
        if (!confirm("Delete this image?")) return;
        try {
          await deleteDoc(doc(db, "gallery", id));
          await deleteImage(url).catch(() => {}); // Best-effort storage cleanup
        } catch (err: any) {
          alert(`Error: ${err.message}`);
        }
      });
    });

    // Alt text update on blur
    galleryGrid.querySelectorAll(".alt-input").forEach((input) => {
      input.addEventListener("blur", async () => {
        const el = input as HTMLInputElement;
        const id = el.dataset.id!;
        const newAlt = el.value.trim();
        const img = allImages.find((i) => i.id === id);
        if (img && img.alt !== newAlt) {
          await setDoc(doc(db, "gallery", id), { alt: newAlt }, { merge: true });
        }
      });
    });
  }

  async function swapOrder(a: GalleryImage, b: GalleryImage) {
    const batch = writeBatch(db);
    batch.update(doc(db, "gallery", a.id), { order: b.order });
    batch.update(doc(db, "gallery", b.id), { order: a.order });
    await batch.commit();
  }

  // Real-time listener
  const q = query(collection(db, "gallery"), orderBy("order", "asc"));
  onSnapshot(q, (snapshot) => {
    allImages = snapshot.docs.map((d) => ({ id: d.id, ...d.data() })) as GalleryImage[];
    renderGallery(allImages);
  });

  // Upload handler
  const uploadInput = document.getElementById("upload-input") as HTMLInputElement;
  uploadInput.addEventListener("change", async () => {
    const files = Array.from(uploadInput.files || []);
    if (files.length === 0) return;

    uploadStatus.classList.remove("hidden");
    let completed = 0;

    // Get next order number
    const startOrder = allImages.length > 0 ? Math.max(...allImages.map((i) => i.order)) + 1 : 1;

    for (let i = 0; i < files.length; i++) {
      uploadStatusText.textContent = `Uploading ${i + 1} of ${files.length}...`;
      uploadProgress.style.width = `${((i) / files.length) * 100}%`;

      try {
        const url = await uploadImage(files[i], "gallery");
        const docRef = doc(collection(db, "gallery"));
        await setDoc(docRef, {
          url,
          alt: "Gallery image",
          order: startOrder + i,
          createdAt: serverTimestamp(),
        });
        completed++;
      } catch (err: any) {
        console.error(`Failed to upload ${files[i].name}:`, err);
      }
    }

    uploadProgress.style.width = "100%";
    uploadStatusText.textContent = `Done! ${completed} of ${files.length} uploaded.`;
    setTimeout(() => uploadStatus.classList.add("hidden"), 3000);
    uploadInput.value = "";
  });

  function escapeAttr(text: string): string {
    return text.replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  }
</script>
