---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Discounts - Asterion Safari">
  <div id="loading" class="min-h-screen flex items-center justify-center bg-[#f8f9fa]">
    <div class="w-10 h-10 border-4 border-orange-200 border-t-orange-500 rounded-full animate-spin"></div>
  </div>

  <div id="discounts-page" class="hidden min-h-screen bg-[#f8f9fa]">
    <header class="bg-white shadow-sm border-b border-gray-100">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/">
          <img src="/photo/logo.svg" alt="Asterion Safari" class="h-10" />
        </a>
        <div class="flex items-center gap-4">
          <a href="/dashboard" class="text-sm text-gray-600 hover:text-orange-500 transition-colors">&larr; Back to Dashboard</a>
          <button
            id="sign-out-btn"
            class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-6 py-2 rounded-full text-sm transition-colors cursor-pointer"
          >
            Sign Out
          </button>
        </div>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-12">
      <div id="list-view">
        <div class="flex items-center justify-between mb-8">
          <h1 class="text-2xl font-bold text-gray-900">Discounts</h1>
          <button id="add-btn" class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-6 py-2 rounded-full text-sm transition-colors cursor-pointer">
            + Add Discount
          </button>
        </div>
        <p class="text-sm text-gray-500 mb-6">Active discounts auto-apply to the tour base price when the selected booking date falls within the range. The highest applicable percent wins.</p>

        <div id="empty-state" class="hidden text-center py-16">
          <p class="text-gray-500">No discounts yet</p>
        </div>

        <div id="discounts-table" class="hidden bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                  <th class="text-left px-6 py-3 font-semibold text-gray-600">Name</th>
                  <th class="text-left px-6 py-3 font-semibold text-gray-600">Percent</th>
                  <th class="text-left px-6 py-3 font-semibold text-gray-600">Start</th>
                  <th class="text-left px-6 py-3 font-semibold text-gray-600">End</th>
                  <th class="text-left px-6 py-3 font-semibold text-gray-600">Status</th>
                  <th class="text-left px-6 py-3 font-semibold text-gray-600">Actions</th>
                </tr>
              </thead>
              <tbody id="discounts-body" class="divide-y divide-gray-50"></tbody>
            </table>
          </div>
        </div>
      </div>

      <div id="form-view" class="hidden">
        <div class="flex items-center justify-between mb-8">
          <h1 id="form-title" class="text-2xl font-bold text-gray-900">Add Discount</h1>
          <button id="back-btn" class="text-sm text-gray-600 hover:text-orange-500 transition-colors cursor-pointer">&larr; Back to list</button>
        </div>

        <form id="discount-form" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Name *</label>
              <input name="name" type="text" required class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" placeholder="Autumn Special" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Percent Off (1-100) *</label>
              <input name="percent" type="number" required min="1" max="100" class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" placeholder="15" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Start Date *</label>
              <input name="startDate" type="date" required class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">End Date *</label>
              <input name="endDate" type="date" required class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            </div>
          </div>

          <div class="flex items-center gap-2">
            <input name="active" type="checkbox" checked class="w-4 h-4 text-orange-500 rounded border-gray-300 focus:ring-orange-400" />
            <label class="text-sm font-semibold text-gray-700">Active</label>
          </div>

          <div class="flex gap-3 pt-4 border-t border-gray-100">
            <button type="submit" id="save-btn" class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-8 py-2.5 rounded-full text-sm transition-colors cursor-pointer">
              Save Discount
            </button>
            <button type="button" id="cancel-btn" class="border border-gray-200 text-gray-600 hover:text-gray-900 font-semibold px-8 py-2.5 rounded-full text-sm transition-colors cursor-pointer">
              Cancel
            </button>
          </div>
          <p id="form-status" class="text-sm hidden"></p>
        </form>
      </div>
    </main>
  </div>
</Layout>

<script>
  import { signOut } from "firebase/auth";
  import { collection, doc, addDoc, setDoc, deleteDoc, onSnapshot, orderBy, query, serverTimestamp } from "firebase/firestore";
  import { requireAuth } from "../lib/auth-guard";
  import { auth, db } from "../lib/firebase";

  await requireAuth();

  document.getElementById("loading")!.classList.add("hidden");
  document.getElementById("discounts-page")!.classList.remove("hidden");

  document.getElementById("sign-out-btn")!.addEventListener("click", async () => {
    await signOut(auth);
    window.location.href = "/login";
  });

  const listView = document.getElementById("list-view")!;
  const formView = document.getElementById("form-view")!;
  const body = document.getElementById("discounts-body")!;
  const table = document.getElementById("discounts-table")!;
  const emptyState = document.getElementById("empty-state")!;
  const form = document.getElementById("discount-form") as HTMLFormElement;
  const formTitle = document.getElementById("form-title")!;
  const formStatus = document.getElementById("form-status")!;

  type Discount = {
    id: string;
    name: string;
    percent: number;
    startDate: string;
    endDate: string;
    active: boolean;
  };

  let all: Discount[] = [];
  let editingId: string | null = null;

  function showList() {
    listView.classList.remove("hidden");
    formView.classList.add("hidden");
    editingId = null;
  }
  function showForm(title: string) {
    listView.classList.add("hidden");
    formView.classList.remove("hidden");
    formTitle.textContent = title;
    formStatus.classList.add("hidden");
  }

  function populate(d: Discount | null) {
    form.reset();
    if (!d) {
      (form.querySelector('[name="active"]') as HTMLInputElement).checked = true;
      return;
    }
    (form.querySelector('[name="name"]') as HTMLInputElement).value = d.name ?? "";
    (form.querySelector('[name="percent"]') as HTMLInputElement).value = String(d.percent ?? "");
    (form.querySelector('[name="startDate"]') as HTMLInputElement).value = d.startDate ?? "";
    (form.querySelector('[name="endDate"]') as HTMLInputElement).value = d.endDate ?? "";
    (form.querySelector('[name="active"]') as HTMLInputElement).checked = d.active !== false;
  }

  function render(items: Discount[]) {
    body.innerHTML = "";
    if (items.length === 0) {
      table.classList.add("hidden");
      emptyState.classList.remove("hidden");
      return;
    }
    emptyState.classList.add("hidden");
    table.classList.remove("hidden");

    items.forEach((d) => {
      const row = document.createElement("tr");
      row.className = "hover:bg-gray-50 transition-colors";
      row.innerHTML = `
        <td class="px-6 py-4 font-medium text-gray-900">${escapeHtml(d.name ?? "")}</td>
        <td class="px-6 py-4 text-gray-700">${d.percent}%</td>
        <td class="px-6 py-4 text-gray-500">${escapeHtml(d.startDate ?? "")}</td>
        <td class="px-6 py-4 text-gray-500">${escapeHtml(d.endDate ?? "")}</td>
        <td class="px-6 py-4">
          <span class="inline-block text-xs font-semibold px-2.5 py-1 rounded-full ${d.active ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-500"}">${d.active ? "Active" : "Inactive"}</span>
        </td>
        <td class="px-6 py-4">
          <div class="flex gap-2">
            <button class="edit-btn text-orange-500 hover:text-orange-600 text-sm font-semibold cursor-pointer" data-id="${d.id}">Edit</button>
            <button class="delete-btn text-red-400 hover:text-red-600 text-sm font-semibold cursor-pointer" data-id="${d.id}">Delete</button>
          </div>
        </td>
      `;
      body.appendChild(row);
    });

    document.querySelectorAll(".edit-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = (btn as HTMLElement).dataset.id!;
        const d = all.find((x) => x.id === id);
        if (!d) return;
        editingId = id;
        populate(d);
        showForm("Edit Discount");
      });
    });
    document.querySelectorAll(".delete-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = (btn as HTMLElement).dataset.id!;
        if (!confirm("Delete this discount? This cannot be undone.")) return;
        await deleteDoc(doc(db, "discounts", id));
      });
    });
  }

  const q = query(collection(db, "discounts"), orderBy("startDate", "asc"));
  onSnapshot(q, (snapshot) => {
    all = snapshot.docs.map((d) => ({ id: d.id, ...(d.data() as any) })) as Discount[];
    render(all);
  });

  document.getElementById("add-btn")!.addEventListener("click", () => {
    editingId = null;
    populate(null);
    showForm("Add Discount");
  });
  document.getElementById("back-btn")!.addEventListener("click", showList);
  document.getElementById("cancel-btn")!.addEventListener("click", showList);

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const startDate = String(fd.get("startDate") ?? "").trim();
    const endDate = String(fd.get("endDate") ?? "").trim();
    if (!startDate || !endDate) {
      formStatus.textContent = "Both start and end dates are required.";
      formStatus.className = "text-sm text-red-600";
      formStatus.classList.remove("hidden");
      return;
    }
    if (endDate < startDate) {
      formStatus.textContent = "End date must be on or after start date.";
      formStatus.className = "text-sm text-red-600";
      formStatus.classList.remove("hidden");
      return;
    }
    const percent = Number(fd.get("percent") ?? 0);
    if (percent < 1 || percent > 100) {
      formStatus.textContent = "Percent must be between 1 and 100.";
      formStatus.className = "text-sm text-red-600";
      formStatus.classList.remove("hidden");
      return;
    }

    const data: any = {
      name: String(fd.get("name") ?? "").trim(),
      percent,
      startDate,
      endDate,
      active: (form.querySelector('[name="active"]') as HTMLInputElement).checked,
      updatedAt: serverTimestamp(),
    };

    const saveBtn = document.getElementById("save-btn") as HTMLButtonElement;
    saveBtn.textContent = "Saving...";
    saveBtn.disabled = true;
    try {
      if (editingId) {
        await setDoc(doc(db, "discounts", editingId), data, { merge: true });
      } else {
        data.createdAt = serverTimestamp();
        await addDoc(collection(db, "discounts"), data);
      }
      formStatus.textContent = "Saved!";
      formStatus.className = "text-sm text-green-600";
      formStatus.classList.remove("hidden");
      setTimeout(showList, 500);
    } catch (err: any) {
      formStatus.textContent = `Error: ${err.message}`;
      formStatus.className = "text-sm text-red-600";
      formStatus.classList.remove("hidden");
    } finally {
      saveBtn.textContent = "Save Discount";
      saveBtn.disabled = false;
    }
  });

  function escapeHtml(text: string): string {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }
</script>
