---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Messages - Asterion Safari">
  <!-- Loading spinner -->
  <div id="loading" class="min-h-screen flex items-center justify-center bg-[#f8f9fa]">
    <div class="w-10 h-10 border-4 border-orange-200 border-t-orange-500 rounded-full animate-spin"></div>
  </div>

  <!-- Messages content (hidden until auth resolves) -->
  <div id="messages-page" class="hidden min-h-screen bg-[#f8f9fa]">
    <!-- Header -->
    <header class="bg-white shadow-sm border-b border-gray-100">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/">
          <img src="/logo.png" alt="Asterion Safari" class="h-10" />
        </a>
        <div class="flex items-center gap-4">
          <a href="/dashboard" class="text-sm text-gray-600 hover:text-orange-500 transition-colors">&larr; Back to Dashboard</a>
          <button
            id="sign-out-btn"
            class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-6 py-2 rounded-full text-sm transition-colors cursor-pointer"
          >
            Sign Out
          </button>
        </div>
      </div>
    </header>

    <!-- Messages body -->
    <main class="max-w-6xl mx-auto px-6 py-12">
      <h1 class="text-2xl font-bold text-gray-900 mb-8">Messages</h1>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-16">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <p class="text-gray-500">No messages yet</p>
      </div>

      <!-- Messages list -->
      <div id="messages-list" class="space-y-4"></div>
    </main>
  </div>
</Layout>

<script>
  import { signOut } from "firebase/auth";
  import { collection, query, orderBy, onSnapshot, doc, updateDoc } from "firebase/firestore";
  import { requireAuth } from "../lib/auth-guard";
  import { auth, db } from "../lib/firebase";

  const user = await requireAuth();

  document.getElementById("loading")!.classList.add("hidden");
  document.getElementById("messages-page")!.classList.remove("hidden");

  document.getElementById("sign-out-btn")!.addEventListener("click", async () => {
    await signOut(auth);
    window.location.href = "/login";
  });

  const messagesList = document.getElementById("messages-list")!;
  const emptyState = document.getElementById("empty-state")!;

  const q = query(collection(db, "messages"), orderBy("createdAt", "desc"));

  onSnapshot(q, (snapshot) => {
    messagesList.innerHTML = "";

    if (snapshot.empty) {
      emptyState.classList.remove("hidden");
      return;
    }

    emptyState.classList.add("hidden");

    snapshot.forEach((docSnap) => {
      const data = docSnap.data();
      const date = data.createdAt?.toDate();
      const dateStr = date
        ? date.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" }) +
          " " +
          date.toLocaleTimeString("en-GB", { hour: "2-digit", minute: "2-digit" })
        : "Just now";

      const isUnread = !data.read;

      const card = document.createElement("div");
      card.className = `bg-white rounded-2xl shadow-sm border p-6 cursor-pointer transition-colors hover:border-orange-200 ${isUnread ? "border-orange-400 border-l-4" : "border-gray-100"}`;
      card.innerHTML = `
        <div class="flex items-start justify-between mb-3">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center flex-shrink-0">
              <span class="text-orange-600 font-bold text-sm">${(data.name || "?")[0].toUpperCase()}</span>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 ${isUnread ? "" : "font-normal"}">${escapeHtml(data.name || "Unknown")}</h3>
              <p class="text-xs text-gray-400">${escapeHtml(data.email || "")}</p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            ${data.source ? `<span class="bg-gray-100 text-gray-600 text-xs px-2 py-0.5 rounded-full">${escapeHtml(data.source)}</span>` : '<span class="bg-gray-100 text-gray-600 text-xs px-2 py-0.5 rounded-full">Contact Form</span>'}
            ${isUnread ? '<span class="bg-orange-500 text-white text-xs font-semibold px-2 py-0.5 rounded-full">New</span>' : ""}
            <span class="text-xs text-gray-400">${dateStr}</span>
          </div>
        </div>
        ${data.phone ? `<p class="text-xs text-gray-400 mb-2">Phone: ${escapeHtml(data.phone)}</p>` : ""}
        <p class="text-sm text-gray-700 leading-relaxed">${escapeHtml(data.message || "No message content")}</p>
      `;

      if (isUnread) {
        card.addEventListener("click", async () => {
          await updateDoc(doc(db, "messages", docSnap.id), { read: true });
        });
      }

      messagesList.appendChild(card);
    });
  });

  function escapeHtml(text: string): string {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }
</script>
