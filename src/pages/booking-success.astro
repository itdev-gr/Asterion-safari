---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Booking Confirmed - Asterion Safari">
  <Header />
  <main class="min-h-[60vh] flex items-center justify-center bg-[#f8f9fa]">
    <div class="text-center max-w-md mx-auto px-6">
      <div class="w-20 h-20 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-gray-900 mb-3">Booking Confirmed!</h1>
      <p class="text-gray-500 mb-8">Thank you for your booking. You will receive a confirmation email shortly with all the details for your safari adventure.</p>
      <a href="/" class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-8 py-3 rounded-full transition-colors inline-block">
        Back to Home
      </a>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import { collection, query, where, getDocs, addDoc, Timestamp } from "firebase/firestore";
  import { db } from "../lib/firebase";

  async function saveBooking() {
    const params = new URLSearchParams(window.location.search);
    const sessionId = params.get("session_id");
    if (!sessionId) return;

    // Best-effort dedup: bookings read may be denied for anonymous users,
    // in which case we proceed and accept a small chance of a duplicate
    // rather than losing the booking entirely.
    try {
      const existing = await getDocs(
        query(collection(db, "bookings"), where("stripeSessionId", "==", sessionId))
      );
      if (!existing.empty) return;
    } catch {
      // ignore — fall through to addDoc
    }

    // Verify session with Stripe via our API
    const res = await fetch("/api/verify-session", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ sessionId }),
    });

    if (!res.ok) return;

    const data = await res.json();

    try {
      await addDoc(collection(db, "bookings"), {
        tour: data.tour,
        guestName: data.guestName,
        date: data.date,
        sharedCount: data.sharedCount,
        soloCount: data.soloCount,
        kidsCount: data.kidsCount ?? 0,
        pickup: data.pickup ?? "",
        extras: Array.isArray(data.extras) ? data.extras : [],
        discountPercent: data.discountPercent ?? 0,
        discountName: data.discountName ?? "",
        baseAmount: data.baseAmount ?? 0,
        discountedBaseAmount: data.discountedBaseAmount ?? 0,
        email: data.email,
        amount: data.amount,
        currency: data.currency,
        status: "paid",
        stripeSessionId: data.stripeSessionId,
        createdAt: Timestamp.now(),
      });
    } catch (err) {
      console.error("Failed to save booking:", err);
    }
  }

  saveBooking();
</script>
