---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bookings - Asterion Safari">
  <!-- Loading spinner -->
  <div id="loading" class="min-h-screen flex items-center justify-center bg-[#f8f9fa]">
    <div class="w-10 h-10 border-4 border-orange-200 border-t-orange-500 rounded-full animate-spin"></div>
  </div>

  <!-- Bookings content (hidden until auth resolves) -->
  <div id="bookings-page" class="hidden min-h-screen bg-[#f8f9fa]">
    <!-- Header -->
    <header class="bg-white shadow-sm border-b border-gray-100">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/">
          <img src="/photo/logo.svg" alt="Asterion Safari" class="h-10" />
        </a>
        <div class="flex items-center gap-4">
          <a href="/dashboard" class="text-sm text-gray-600 hover:text-orange-500 transition-colors">&larr; Back to Dashboard</a>
          <button
            id="sign-out-btn"
            class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-6 py-2 rounded-full text-sm transition-colors cursor-pointer"
          >
            Sign Out
          </button>
        </div>
      </div>
    </header>

    <!-- Bookings body -->
    <main class="max-w-6xl mx-auto px-6 py-12">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Bookings</h1>
        <div class="flex gap-2">
          <select id="filter-status" class="text-sm border border-gray-200 rounded-lg px-3 py-2 bg-white text-gray-700">
            <option value="all">All Statuses</option>
            <option value="paid">Paid</option>
            <option value="scheduled">Scheduled</option>
            <option value="done">Done</option>
            <option value="canceled">Canceled</option>
          </select>
        </div>
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-16">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <p class="text-gray-500">No bookings yet</p>
      </div>

      <!-- Bookings table -->
      <div id="bookings-table" class="hidden bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
              <tr>
                <th class="text-left px-6 py-3 font-semibold text-gray-600">Tour</th>
                <th class="text-left px-6 py-3 font-semibold text-gray-600">Guest</th>
                <th class="text-left px-6 py-3 font-semibold text-gray-600">Email</th>
                <th class="text-left px-6 py-3 font-semibold text-gray-600">Tour Date</th>
                <th class="text-left px-6 py-3 font-semibold text-gray-600">Booked On</th>
                <th class="text-left px-6 py-3 font-semibold text-gray-600">Amount</th>
                <th class="text-left px-6 py-3 font-semibold text-gray-600">Status</th>
                <th class="text-left px-6 py-3 font-semibold text-gray-600">Actions</th>
              </tr>
            </thead>
            <tbody id="bookings-body" class="divide-y divide-gray-50"></tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  import { signOut } from "firebase/auth";
  import { collection, query, orderBy, onSnapshot, doc, updateDoc } from "firebase/firestore";
  import { requireAuth } from "../lib/auth-guard";
  import { auth, db } from "../lib/firebase";

  const user = await requireAuth();

  document.getElementById("loading")!.classList.add("hidden");
  document.getElementById("bookings-page")!.classList.remove("hidden");

  document.getElementById("sign-out-btn")!.addEventListener("click", async () => {
    await signOut(auth);
    window.location.href = "/login";
  });

  const bookingsBody = document.getElementById("bookings-body")!;
  const bookingsTable = document.getElementById("bookings-table")!;
  const emptyState = document.getElementById("empty-state")!;
  const filterStatus = document.getElementById("filter-status") as HTMLSelectElement;

  type Booking = {
    id: string;
    tour: string;
    guestName: string;
    email: string;
    date: string;
    amount: number;
    currency: string;
    status: string;
    sharedCount: number;
    soloCount: number;
    createdAt: any;
  };

  let allBookings: Booking[] = [];

  const statusColors: Record<string, string> = {
    paid: "bg-green-100 text-green-700",
    scheduled: "bg-blue-100 text-blue-700",
    done: "bg-gray-100 text-gray-700",
    canceled: "bg-red-100 text-red-700",
  };

  const statusOptions = ["paid", "scheduled", "done", "canceled"];

  function renderBookings(bookings: Booking[]) {
    bookingsBody.innerHTML = "";

    if (bookings.length === 0) {
      bookingsTable.classList.add("hidden");
      emptyState.classList.remove("hidden");
      return;
    }

    emptyState.classList.add("hidden");
    bookingsTable.classList.remove("hidden");

    bookings.forEach((booking) => {
      const row = document.createElement("tr");
      row.className = "hover:bg-gray-50 transition-colors";

      const colorClass = statusColors[booking.status] || "bg-gray-100 text-gray-700";

      const quads: string[] = [];
      if (booking.sharedCount > 0) quads.push(`${booking.sharedCount} shared`);
      if (booking.soloCount > 0) quads.push(`${booking.soloCount} solo`);
      const quadInfo = quads.length > 0 ? `<span class="text-xs text-gray-400 block">${escapeHtml(quads.join(", "))}</span>` : "";

      const options = statusOptions
        .map((s) => `<option value="${s}" ${s === booking.status ? "selected" : ""}>${s.charAt(0).toUpperCase() + s.slice(1)}</option>`)
        .join("");

      const bookedOn = booking.createdAt?.toDate
        ? booking.createdAt.toDate().toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })
        : "";

      row.innerHTML = `
        <td class="px-6 py-4">
          <span class="font-medium text-gray-900">${escapeHtml(booking.tour)}</span>
          ${quadInfo}
        </td>
        <td class="px-6 py-4 text-gray-700">${escapeHtml(booking.guestName)}</td>
        <td class="px-6 py-4 text-gray-500">${escapeHtml(booking.email)}</td>
        <td class="px-6 py-4 text-gray-700">${escapeHtml(booking.date)}</td>
        <td class="px-6 py-4 text-gray-400 text-xs">${bookedOn}</td>
        <td class="px-6 py-4 font-medium text-gray-900">&euro;${booking.amount.toFixed(2)}</td>
        <td class="px-6 py-4">
          <span class="inline-block text-xs font-semibold px-2.5 py-1 rounded-full ${colorClass}">${booking.status.charAt(0).toUpperCase() + booking.status.slice(1)}</span>
        </td>
        <td class="px-6 py-4">
          <select class="status-select text-xs border border-gray-200 rounded-lg px-2 py-1 bg-white" data-id="${booking.id}">
            ${options}
          </select>
        </td>
      `;

      bookingsBody.appendChild(row);
    });

    document.querySelectorAll(".status-select").forEach((select) => {
      select.addEventListener("change", async (e) => {
        const target = e.target as HTMLSelectElement;
        const bookingId = target.dataset.id!;
        const newStatus = target.value;
        await updateDoc(doc(db, "bookings", bookingId), { status: newStatus });
      });
    });
  }

  const q = query(collection(db, "bookings"), orderBy("createdAt", "desc"));

  onSnapshot(q, (snapshot) => {
    allBookings = snapshot.docs.map((docSnap) => ({
      id: docSnap.id,
      ...docSnap.data(),
    })) as Booking[];

    applyFilter();
  });

  function applyFilter() {
    const status = filterStatus.value;
    const filtered = status === "all" ? allBookings : allBookings.filter((b) => b.status === status);
    renderBookings(filtered);
  }

  filterStatus.addEventListener("change", applyFilter);

  function escapeHtml(text: string): string {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }
</script>
