---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Manage Tours - Asterion Safari">
  <!-- Loading spinner -->
  <div id="loading" class="min-h-screen flex items-center justify-center bg-[#f8f9fa]">
    <div class="w-10 h-10 border-4 border-orange-200 border-t-orange-500 rounded-full animate-spin"></div>
  </div>

  <!-- Tours management content -->
  <div id="tours-page" class="hidden min-h-screen bg-[#f8f9fa]">
    <!-- Header -->
    <header class="bg-white shadow-sm border-b border-gray-100">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/">
          <img src="/photo/logo.svg" alt="Asterion Safari" class="h-10" />
        </a>
        <div class="flex items-center gap-4">
          <a href="/dashboard" class="text-sm text-gray-600 hover:text-orange-500 transition-colors">&larr; Back to Dashboard</a>
          <button
            id="sign-out-btn"
            class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-6 py-2 rounded-full text-sm transition-colors cursor-pointer"
          >
            Sign Out
          </button>
        </div>
      </div>
    </header>

    <!-- Main -->
    <main class="max-w-6xl mx-auto px-6 py-12">
      <!-- LIST VIEW -->
      <div id="list-view">
        <div class="flex items-center justify-between mb-8">
          <h1 class="text-2xl font-bold text-gray-900">Tours</h1>
          <button id="add-tour-btn" class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-6 py-2 rounded-full text-sm transition-colors cursor-pointer">
            + Add Tour
          </button>
        </div>

        <div id="empty-state" class="hidden text-center py-16">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
          </svg>
          <p class="text-gray-500">No tours yet</p>
        </div>

        <div id="tours-table" class="hidden bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                  <th class="text-left px-6 py-3 font-semibold text-gray-600">Title</th>
                  <th class="text-left px-6 py-3 font-semibold text-gray-600">Slug</th>
                  <th class="text-left px-6 py-3 font-semibold text-gray-600">Price</th>
                  <th class="text-left px-6 py-3 font-semibold text-gray-600">Order</th>
                  <th class="text-left px-6 py-3 font-semibold text-gray-600">Status</th>
                  <th class="text-left px-6 py-3 font-semibold text-gray-600">Actions</th>
                </tr>
              </thead>
              <tbody id="tours-body" class="divide-y divide-gray-50"></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- EDIT / ADD VIEW -->
      <div id="form-view" class="hidden">
        <div class="flex items-center justify-between mb-8">
          <h1 id="form-title" class="text-2xl font-bold text-gray-900">Add Tour</h1>
          <button id="back-to-list-btn" class="text-sm text-gray-600 hover:text-orange-500 transition-colors cursor-pointer">&larr; Back to list</button>
        </div>

        <form id="tour-form" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 space-y-6">
          <!-- Basic info -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Title *</label>
              <input name="title" type="text" required class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Short Title (nav/cards) *</label>
              <input name="shortTitle" type="text" required class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Slug *</label>
              <input name="slug" type="text" required pattern="[a-z0-9-]+" class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" placeholder="e.g. day-tour" />
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Price (EUR) *</label>
                <input name="price" type="number" required min="0" class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Price (cents) *</label>
                <input name="priceCents" type="number" required min="0" class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
              </div>
            </div>
          </div>

          <!-- URLs -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Card Image</label>
              <input name="cardImage" type="hidden" />
              <div class="flex items-center gap-3">
                <label class="cursor-pointer bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium px-4 py-2.5 rounded-xl transition-colors">
                  Choose File
                  <input type="file" accept="image/*" id="card-image-file" class="hidden" />
                </label>
                <span id="card-image-name" class="text-xs text-gray-400 truncate"></span>
              </div>
              <div id="card-image-preview" class="mt-2 hidden">
                <img id="card-image-thumb" src="" alt="Preview" class="w-32 h-20 object-cover rounded-lg border border-gray-200" />
              </div>
              <p id="card-image-status" class="text-xs text-gray-400 mt-1 hidden"></p>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Map Embed URL</label>
              <input name="mapEmbedUrl" type="text" class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            </div>
          </div>

          <!-- Duration, Group Size, Pickup Locations -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Duration</label>
              <input name="duration" type="text" class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" placeholder="4,5 Hours" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Group Size</label>
              <input name="groupSize" type="text" class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" placeholder="10 people" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Pickup Locations</label>
              <input name="pickupLocations" type="text" class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            </div>
          </div>

          <!-- Order & Active -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-end">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Order</label>
              <input name="order" type="number" value="1" class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            </div>
            <div class="flex items-center gap-2 pb-1">
              <input name="active" type="checkbox" checked class="w-4 h-4 text-orange-500 rounded border-gray-300 focus:ring-orange-400" />
              <label class="text-sm font-semibold text-gray-700">Active</label>
            </div>
          </div>

          <!-- Text areas -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">About Text</label>
            <textarea name="aboutText" rows="4" class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400"></textarea>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Short Description (for cards)</label>
            <textarea name="shortDescription" rows="2" class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400"></textarea>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Long Description (for homepage)</label>
            <textarea name="longDescription" rows="4" class="border border-gray-200 rounded-xl px-4 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400"></textarea>
          </div>

          <!-- Dynamic lists -->
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Highlights</label>
              <div id="highlights-list" class="space-y-2"></div>
              <button type="button" data-add="highlights" class="mt-2 text-sm text-orange-500 hover:text-orange-600 cursor-pointer">+ Add highlight</button>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Included</label>
              <div id="included-list" class="space-y-2"></div>
              <button type="button" data-add="included" class="mt-2 text-sm text-orange-500 hover:text-orange-600 cursor-pointer">+ Add item</button>
            </div>
          </div>

          <!-- Images -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Gallery Images</label>
            <div id="images-list" class="space-y-2"></div>
            <button type="button" id="add-image-btn" class="mt-2 text-sm text-orange-500 hover:text-orange-600 cursor-pointer">+ Add image</button>
          </div>


          <!-- Submit -->
          <div class="flex gap-3 pt-4 border-t border-gray-100">
            <button type="submit" id="save-btn" class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-8 py-2.5 rounded-full text-sm transition-colors cursor-pointer">
              Save Tour
            </button>
            <button type="button" id="cancel-btn" class="border border-gray-200 text-gray-600 hover:text-gray-900 font-semibold px-8 py-2.5 rounded-full text-sm transition-colors cursor-pointer">
              Cancel
            </button>
          </div>
          <p id="form-status" class="text-sm hidden"></p>
        </form>
      </div>
    </main>
  </div>
</Layout>

<script>
  import { signOut } from "firebase/auth";
  import { collection, doc, setDoc, deleteDoc, onSnapshot, orderBy, query, serverTimestamp } from "firebase/firestore";
  import { requireAuth } from "../lib/auth-guard";
  import { auth, db } from "../lib/firebase";
  import { uploadImage } from "../lib/upload-image";

  const user = await requireAuth();

  document.getElementById("loading")!.classList.add("hidden");
  document.getElementById("tours-page")!.classList.remove("hidden");

  document.getElementById("sign-out-btn")!.addEventListener("click", async () => {
    await signOut(auth);
    window.location.href = "/login";
  });

  // Card image file upload
  const cardImageFile = document.getElementById("card-image-file") as HTMLInputElement;
  const cardImageInput = document.querySelector('[name="cardImage"]') as HTMLInputElement;
  const cardImagePreview = document.getElementById("card-image-preview")!;
  const cardImageThumb = document.getElementById("card-image-thumb") as HTMLImageElement;
  const cardImageStatus = document.getElementById("card-image-status")!;
  const cardImageName = document.getElementById("card-image-name")!;

  cardImageFile.addEventListener("change", async () => {
    const file = cardImageFile.files?.[0];
    if (!file) return;
    cardImageName.textContent = file.name;
    cardImageStatus.textContent = "Uploading...";
    cardImageStatus.classList.remove("hidden");
    try {
      const url = await uploadImage(file, "tours");
      cardImageInput.value = url;
      cardImageThumb.src = url;
      cardImagePreview.classList.remove("hidden");
      cardImageStatus.textContent = "Uploaded!";
      setTimeout(() => cardImageStatus.classList.add("hidden"), 2000);
    } catch (err: any) {
      cardImageStatus.textContent = `Error: ${err.message}`;
    }
  });

  // DOM refs
  const listView = document.getElementById("list-view")!;
  const formView = document.getElementById("form-view")!;
  const toursBody = document.getElementById("tours-body")!;
  const toursTable = document.getElementById("tours-table")!;
  const emptyState = document.getElementById("empty-state")!;
  const tourForm = document.getElementById("tour-form") as HTMLFormElement;
  const formTitle = document.getElementById("form-title")!;
  const formStatus = document.getElementById("form-status")!;

  let editingSlug: string | null = null;

  type Tour = {
    slug: string;
    title: string;
    shortTitle: string;
    price: number;
    priceCents: number;
    order: number;
    active: boolean;
    [key: string]: any;
  };

  let allTours: Tour[] = [];

  // Show list / form
  function showList() {
    listView.classList.remove("hidden");
    formView.classList.add("hidden");
    editingSlug = null;
  }
  function showForm(title: string) {
    listView.classList.add("hidden");
    formView.classList.remove("hidden");
    formTitle.textContent = title;
    formStatus.classList.add("hidden");
  }

  // Dynamic list helpers
  function addListRow(containerId: string, value = "") {
    const container = document.getElementById(`${containerId}-list`)!;
    const row = document.createElement("div");
    row.className = "flex gap-2";
    row.innerHTML = `
      <input type="text" value="${escapeAttr(value)}" class="border border-gray-200 rounded-xl px-3 py-2 w-full text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 dynamic-list-input" data-list="${containerId}" />
      <button type="button" class="text-red-400 hover:text-red-600 text-sm shrink-0 remove-row-btn">&times;</button>
    `;
    container.appendChild(row);
    row.querySelector(".remove-row-btn")!.addEventListener("click", () => row.remove());
  }

  function getListValues(containerId: string): string[] {
    return Array.from(document.querySelectorAll(`#${containerId}-list .dynamic-list-input`))
      .map((el) => (el as HTMLInputElement).value.trim())
      .filter(Boolean);
  }

  // Image rows
  function addImageRow(src = "", alt = "") {
    const container = document.getElementById("images-list")!;
    const row = document.createElement("div");
    row.className = "flex gap-2 items-center";
    row.innerHTML = `
      <input type="hidden" value="${escapeAttr(src)}" class="img-src" />
      <label class="cursor-pointer bg-gray-100 hover:bg-gray-200 text-gray-700 text-xs font-medium px-3 py-2 rounded-lg transition-colors shrink-0">
        ${src ? "Replace" : "Upload"}
        <input type="file" accept="image/*" class="hidden img-file-input" />
      </label>
      <img src="${escapeAttr(src)}" alt="" class="w-16 h-10 object-cover rounded border border-gray-200 shrink-0 img-thumb ${src ? "" : "hidden"}" />
      <span class="text-xs text-gray-400 img-upload-status"></span>
      <input type="text" value="${escapeAttr(alt)}" placeholder="Alt text" class="border border-gray-200 rounded-xl px-3 py-2 w-40 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 img-alt" />
      <button type="button" class="text-red-400 hover:text-red-600 text-sm shrink-0 remove-row-btn">&times;</button>
    `;
    container.appendChild(row);
    row.querySelector(".remove-row-btn")!.addEventListener("click", () => row.remove());

    // File upload handler
    const fileInput = row.querySelector(".img-file-input") as HTMLInputElement;
    fileInput.addEventListener("change", async () => {
      const file = fileInput.files?.[0];
      if (!file) return;
      const status = row.querySelector(".img-upload-status") as HTMLElement;
      const thumb = row.querySelector(".img-thumb") as HTMLImageElement;
      const hiddenInput = row.querySelector(".img-src") as HTMLInputElement;
      const label = row.querySelector("label") as HTMLLabelElement;
      status.textContent = "Uploading...";
      try {
        const { uploadImage } = await import("../lib/upload-image");
        const url = await uploadImage(file, "tours");
        hiddenInput.value = url;
        thumb.src = url;
        thumb.classList.remove("hidden");
        status.textContent = "";
        label.childNodes[0].textContent = "Replace ";
      } catch (err: any) {
        status.textContent = `Error: ${err.message}`;
      }
    });
  }

  function getImageValues(): { src: string; alt: string }[] {
    const rows = document.querySelectorAll("#images-list > div");
    return Array.from(rows).map((row) => ({
      src: (row.querySelector(".img-src") as HTMLInputElement).value.trim(),
      alt: (row.querySelector(".img-alt") as HTMLInputElement).value.trim(),
    })).filter((i) => i.src);
  }

  // Populate form
  function populateForm(tour: Tour | null) {
    tourForm.reset();
    // Clear dynamic lists
    ["highlights", "included"].forEach((id) => {
      document.getElementById(`${id}-list`)!.innerHTML = "";
    });
    document.getElementById("images-list")!.innerHTML = "";

    // Reset card image preview
    cardImagePreview.classList.add("hidden");
    cardImageThumb.src = "";
    cardImageName.textContent = "";
    cardImageStatus.classList.add("hidden");

    if (!tour) return;

    // Simple fields
    const fields = ["title", "shortTitle", "slug", "price", "priceCents", "cardImage", "mapEmbedUrl", "order", "aboutText", "shortDescription", "longDescription", "duration", "groupSize", "pickupLocations"];
    fields.forEach((f) => {
      const el = tourForm.querySelector(`[name="${f}"]`) as HTMLInputElement | HTMLTextAreaElement;
      if (el && tour[f] !== undefined) el.value = String(tour[f]);
    });

    // Show card image preview if exists
    if (tour.cardImage) {
      cardImageThumb.src = tour.cardImage;
      cardImagePreview.classList.remove("hidden");
    }

    // Active checkbox
    const activeEl = tourForm.querySelector('[name="active"]') as HTMLInputElement;
    if (activeEl) activeEl.checked = tour.active !== false;

    // Dynamic lists
    (tour.highlights || []).forEach((v: string) => addListRow("highlights", v));
    (tour.included || []).forEach((v: string) => addListRow("included", v));
    (tour.images || []).forEach((img: any) => addImageRow(img.src, img.alt));
  }

  // Render list
  function renderTours(tours: Tour[]) {
    toursBody.innerHTML = "";
    if (tours.length === 0) {
      toursTable.classList.add("hidden");
      emptyState.classList.remove("hidden");
      return;
    }
    emptyState.classList.add("hidden");
    toursTable.classList.remove("hidden");

    tours.forEach((tour) => {
      const row = document.createElement("tr");
      row.className = "hover:bg-gray-50 transition-colors";
      row.innerHTML = `
        <td class="px-6 py-4 font-medium text-gray-900">${escapeHtml(tour.title)}</td>
        <td class="px-6 py-4 text-gray-500 text-xs font-mono">${escapeHtml(tour.slug)}</td>
        <td class="px-6 py-4 text-gray-700">&euro;${tour.price}</td>
        <td class="px-6 py-4 text-gray-500">${tour.order ?? ''}</td>
        <td class="px-6 py-4">
          <span class="inline-block text-xs font-semibold px-2.5 py-1 rounded-full ${tour.active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}">${tour.active ? 'Active' : 'Inactive'}</span>
        </td>
        <td class="px-6 py-4">
          <div class="flex gap-2">
            <button class="edit-tour-btn text-orange-500 hover:text-orange-600 text-sm font-semibold cursor-pointer" data-slug="${tour.slug}">Edit</button>
            <button class="delete-tour-btn text-red-400 hover:text-red-600 text-sm font-semibold cursor-pointer" data-slug="${tour.slug}">Delete</button>
          </div>
        </td>
      `;
      toursBody.appendChild(row);
    });

    // Edit buttons
    document.querySelectorAll(".edit-tour-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const slug = (btn as HTMLElement).dataset.slug!;
        const tour = allTours.find((t) => t.slug === slug);
        if (!tour) return;
        editingSlug = slug;
        populateForm(tour);
        showForm("Edit Tour");
      });
    });

    // Delete buttons
    document.querySelectorAll(".delete-tour-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const slug = (btn as HTMLElement).dataset.slug!;
        if (!confirm(`Delete tour "${slug}"? This cannot be undone.`)) return;
        await deleteDoc(doc(db, "tours", slug));
        sessionStorage.removeItem("nav-tours");
      });
    });
  }

  // Real-time listener
  const q = query(collection(db, "tours"), orderBy("order", "asc"));
  onSnapshot(q, (snapshot) => {
    allTours = snapshot.docs.map((d) => ({ slug: d.id, ...d.data() })) as Tour[];
    renderTours(allTours);
  });

  // Add tour button
  document.getElementById("add-tour-btn")!.addEventListener("click", () => {
    editingSlug = null;
    populateForm(null);
    showForm("Add Tour");
  });

  // Back / Cancel
  document.getElementById("back-to-list-btn")!.addEventListener("click", showList);
  document.getElementById("cancel-btn")!.addEventListener("click", showList);

  // Add row buttons
  document.querySelectorAll("[data-add]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const listId = (btn as HTMLElement).dataset.add!;
      addListRow(listId);
    });
  });
  document.getElementById("add-image-btn")!.addEventListener("click", () => addImageRow());

  // Form submit
  tourForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(tourForm);
    const slug = (formData.get("slug") as string).trim();

    if (!slug) {
      formStatus.textContent = "Slug is required.";
      formStatus.className = "text-sm text-red-600";
      return;
    }

    const data: any = {
      title: formData.get("title"),
      shortTitle: formData.get("shortTitle"),
      price: Number(formData.get("price")),
      priceCents: Number(formData.get("priceCents")),
      cardImage: formData.get("cardImage"),
      mapEmbedUrl: formData.get("mapEmbedUrl"),
      order: Number(formData.get("order") || 1),
      active: (tourForm.querySelector('[name="active"]') as HTMLInputElement).checked,
      aboutText: formData.get("aboutText"),
      shortDescription: formData.get("shortDescription"),
      longDescription: formData.get("longDescription"),
      duration: formData.get("duration"),
      groupSize: formData.get("groupSize"),
      pickupLocations: formData.get("pickupLocations"),
      highlights: getListValues("highlights"),
      included: getListValues("included"),
      images: getImageValues(),
      updatedAt: serverTimestamp(),
    };

    // If creating, add createdAt
    if (!editingSlug) {
      data.createdAt = serverTimestamp();
    }

    const saveBtn = document.getElementById("save-btn") as HTMLButtonElement;
    saveBtn.textContent = "Saving...";
    saveBtn.disabled = true;

    try {
      // If slug changed during edit, delete old doc
      if (editingSlug && editingSlug !== slug) {
        await deleteDoc(doc(db, "tours", editingSlug));
      }
      await setDoc(doc(db, "tours", slug), data, { merge: true });
      sessionStorage.removeItem("nav-tours");

      formStatus.textContent = "Tour saved successfully!";
      formStatus.className = "text-sm text-green-600";
      setTimeout(showList, 800);
    } catch (err: any) {
      formStatus.textContent = `Error: ${err.message}`;
      formStatus.className = "text-sm text-red-600";
    } finally {
      saveBtn.textContent = "Save Tour";
      saveBtn.disabled = false;
    }
  });

  function escapeHtml(text: string): string {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  function escapeAttr(text: string): string {
    return text.replace(/"/g, "&quot;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  }
</script>
