<section class="py-10 sm:py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div id="tour-descriptions-container" class="flex flex-col md:grid md:grid-cols-2 gap-6 md:gap-x-8 md:gap-y-6">
      <!-- Populated dynamically -->
    </div>
  </div>
</section>

<script>
  async function loadTourDescriptions() {
    const cached = sessionStorage.getItem('nav-tours');
    let tours;
    if (cached) {
      try { tours = JSON.parse(cached); } catch { tours = null; }
    }
    if (!tours) {
      try {
        const res = await fetch('/api/get-tours');
        tours = await res.json();
        sessionStorage.setItem('nav-tours', JSON.stringify(tours));
      } catch { tours = []; }
    }

    const container = document.getElementById('tour-descriptions-container');
    if (!container || !tours.length) return;

    // Build text blocks
    const textBlocks = tours.map((t: any) => `
      <div class="flex flex-col min-w-0 text-center md:text-center">
        <h2 class="text-xl sm:text-2xl font-bold text-dark mb-3 sm:mb-4">${t.shortTitle} Activity</h2>
        <p class="text-gray-600 text-sm sm:text-base leading-relaxed flex-1">${t.longDescription}</p>
      </div>
    `).join('');

    // Build map blocks
    const mapBlocks = tours.map((t: any) => t.mapEmbedUrl ? `
      <div class="flex-1 min-w-0 text-center mt-0 md:mt-2">
        <iframe
          src="${t.mapEmbedUrl}"
          width="100%"
          height="300"
          style="border:0; border-radius: 12px;"
          allowfullscreen=""
          loading="lazy"
          title="${t.shortTitle} Activity Route"
        ></iframe>
      </div>
    ` : '').join('');

    container.innerHTML = textBlocks + mapBlocks;
  }
  loadTourDescriptions();
</script>
