---
import { getActiveTours } from '../lib/firebase-server';

const tours = await getActiveTours() as any[];
---

<section class="py-10 sm:py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:grid md:grid-cols-2 gap-6 md:gap-x-8 md:gap-y-6">
      {tours.map((tour) => (
        <div class="flex flex-col min-w-0 text-center md:text-center">
          <h2 class="text-xl sm:text-2xl font-bold text-dark mb-3 sm:mb-4">{tour.shortTitle || tour.title}</h2>
          <p class="text-gray-600 text-sm sm:text-base leading-relaxed mb-4">{tour.aboutText || tour.shortDescription || ''}</p>
          {tour.mapEmbedUrl && (
            <div class="mt-auto">
              <iframe
                src={tour.mapEmbedUrl}
                width="100%"
                height="300"
                style="border:0; border-radius: 12px;"
                allowfullscreen=""
                loading="lazy"
                title={`${tour.shortTitle || tour.title} Route`}
              />
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
