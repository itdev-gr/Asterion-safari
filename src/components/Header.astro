---
import LanguageToggle from './LanguageToggle.astro';
---

<header id="main-header" class="sticky top-0 z-50">
  <div id="top-bar" class="text-white text-sm sm:text-base transition-all duration-200" style="background-color: transparent;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-center gap-6 h-9 sm:h-11">
      <a href="tel:+306984136633" class="hover:text-primary transition-colors">+30 698 413 6633</a>
      <a href="mailto:asterionquads@gmail.com" class="hover:text-primary transition-colors">asterionquads@gmail.com</a>
    </div>
  </div>

  <nav
    id="main-nav"
    class="transition-all duration-200 overflow-visible"
    style="background-color: transparent;"
    aria-label="Main navigation"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between min-h-[100px] max-lg:min-h-[72px] py-0.5 overflow-visible">
        <a href="/" class="flex items-center shrink-0 -ml-[96px] lg:-ml-[96px] max-lg:ml-0">
          <img src="/photo/logo.webp" alt="Asterion Safari - Quad Biking Adventures" width="120" height="120" class="h-[120px] w-auto object-contain max-lg:h-20" />
        </a>

        <div class="hidden lg:flex flex-1 justify-center items-center gap-8">
          <a href="/" class="nav-desktop-link transition-colors font-medium" data-i18n="nav.home">Home</a>
          <div class="relative group">
            <button
              type="button"
              class="nav-desktop-link flex items-center gap-1 transition-colors font-medium"
              aria-expanded="false"
              aria-haspopup="true"
            >
              <span data-i18n="nav.activities">Quad Safari Activities</span>
              <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute top-full left-0 mt-1 w-48 py-2 bg-white rounded-md shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
              <a href="/day-tour" class="block px-4 py-2 text-dark hover:bg-gray-50 hover:text-primary transition-colors" data-i18n="nav.dayTour">Day Tour</a>
              <a href="/evening-tour" class="block px-4 py-2 text-dark hover:bg-gray-50 hover:text-primary transition-colors" data-i18n="nav.eveningTour">Evening Tour</a>
            </div>
          </div>
          <a href="/about" class="nav-desktop-link transition-colors font-medium" data-i18n="nav.about">About Us</a>
          <a href="/gallery" class="nav-desktop-link transition-colors font-medium" data-i18n="nav.gallery">Gallery</a>
          <a href="/contact" class="nav-desktop-link transition-colors font-medium" data-i18n="nav.contact">Contact</a>
        </div>

        <div class="hidden lg:flex items-center shrink-0 ml-6 nav-lang-toggle">
          <LanguageToggle />
        </div>

        <button
          type="button"
          id="mobile-menu-btn"
          class="nav-mobile-btn lg:hidden p-2 rounded-lg hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-primary transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg id="icon-open" class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-7 h-7 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Fullscreen mobile menu overlay (lg:hidden = hide on desktop >=1024px) -->
  <div
    id="mobile-menu-overlay"
    class="fixed inset-0 z-[100] lg:hidden opacity-0 pointer-events-none transition-opacity duration-300 ease-out overflow-visible"
    aria-hidden="true"
    inert
  >
    <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm z-0"></div>
    <div
      id="mobile-menu-panel"
      class="absolute inset-0 flex flex-col bg-white transform transition-transform duration-300 ease-out translate-y-[-100%] overflow-hidden z-[1]"
    >
      <div class="flex items-center justify-between px-4 sm:px-6 h-16 min-h-16 border-b border-gray-200 shrink-0 bg-white">
        <a href="/" class="flex items-center" id="mobile-menu-logo-link">
          <img src="/photo/logo.webp" alt="Asterion Safari - Quad Biking Adventures" width="80" height="80" class="h-20 w-auto object-contain" />
        </a>
        <div class="w-11 shrink-0" aria-hidden="true"></div>
      </div>
      <nav class="flex-1 flex flex-col justify-start px-6 pt-4 pb-8 overflow-y-auto" aria-label="Mobile navigation">
        <div class="space-y-1">
          <div class="flex items-center justify-between gap-4 py-3 border-b border-gray-100">
            <span class="text-sm text-gray-500" data-i18n="language">Language</span>
            <LanguageToggle />
          </div>
          <a href="/" class="mobile-menu-link block py-4 text-xl font-semibold text-dark hover:text-primary transition-colors" data-i18n="nav.home">Home</a>
          <div class="py-2" id="mobile-activities-wrap">
            <button
              type="button"
              id="mobile-activities-toggle"
              class="flex w-full items-center justify-between py-3 text-left text-lg font-semibold text-gray-500 hover:text-primary transition-colors"
              aria-expanded="false"
              aria-controls="mobile-activities-submenu"
            >
              <span data-i18n="nav.activities">Quad Safari Activities</span>
              <svg id="mobile-activities-chevron" class="w-5 h-5 shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div id="mobile-activities-submenu" class="grid max-h-0 overflow-hidden opacity-0 transition-all duration-200 ease-out grid-rows-[0fr]" aria-hidden="true">
              <div class="min-h-0">
                <a href="/day-tour" class="mobile-menu-link block py-3 pl-4 text-xl text-dark hover:text-primary transition-colors" data-i18n="nav.dayTour">Day Tour</a>
                <a href="/evening-tour" class="mobile-menu-link block py-3 pl-4 text-xl text-dark hover:text-primary transition-colors" data-i18n="nav.eveningTour">Evening Tour</a>
              </div>
            </div>
          </div>
          <a href="/about" class="mobile-menu-link block py-4 text-xl font-semibold text-dark hover:text-primary transition-colors" data-i18n="nav.about">About Us</a>
          <a href="/gallery" class="mobile-menu-link block py-4 text-xl font-semibold text-dark hover:text-primary transition-colors" data-i18n="nav.gallery">Gallery</a>
          <a href="/contact" class="mobile-menu-link block py-4 text-xl font-semibold text-dark hover:text-primary transition-colors" data-i18n="nav.contact">Contact</a>
        </div>
      </nav>
    </div>
    <button
      type="button"
      id="mobile-menu-close"
      class="fixed z-[200] flex items-center justify-center w-12 h-12 min-w-12 min-h-12 rounded-full text-gray-800 bg-white shadow-lg border-2 border-gray-300 hover:bg-gray-50 active:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 transition-colors touch-manipulation"
      style="top: max(1rem, env(safe-area-inset-top)); right: max(1rem, env(safe-area-inset-right)); display: none;"
      aria-label="Close menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
</header>

<style>
  /* Top bar: transparent at top, dark on scroll */
  :global(#main-header:not(.is-scrolled) #top-bar) {
    background-color: transparent !important;
  }
  :global(#main-header.is-scrolled #top-bar) {
    background-color: var(--color-dark) !important;
  }

  /* Top of page: white text; after scroll: dark text (sticky header) */
  :global(#main-nav:not(.is-scrolled) .nav-desktop-link) {
    color: white;
  }
  :global(#main-nav:not(.is-scrolled) .nav-desktop-link:hover) {
    color: rgba(255, 255, 255, 0.9);
  }
  :global(#main-nav.is-scrolled .nav-desktop-link) {
    color: var(--color-dark);
  }
  :global(#main-nav.is-scrolled .nav-desktop-link:hover) {
    color: var(--color-primary);
  }

  :global(#main-nav:not(.is-scrolled) .nav-mobile-btn) {
    color: white;
  }
  :global(#main-nav:not(.is-scrolled) .nav-mobile-btn:hover) {
    background-color: rgba(255, 255, 255, 0.1);
  }
  :global(#main-nav.is-scrolled .nav-mobile-btn) {
    color: var(--color-dark);
  }
  :global(#main-nav.is-scrolled .nav-mobile-btn:hover) {
    background-color: rgb(243 244 246);
  }

  :global(#main-nav:not(.is-scrolled) .nav-lang-toggle .lang-toggle) {
    background: transparent !important;
    border-color: rgba(255, 255, 255, 0.5);
  }
  :global(#main-nav:not(.is-scrolled) .nav-lang-toggle .lang-option) {
    color: white;
    background: transparent !important;
    box-shadow: none !important;
  }
  :global(#main-nav:not(.is-scrolled) .nav-lang-toggle .lang-option[aria-pressed="true"]) {
    background: rgba(255, 255, 255, 0.15) !important;
    color: white;
  }
  :global(#main-nav:not(.is-scrolled) .nav-lang-toggle .lang-option:hover) {
    color: white;
  }
  :global(#main-nav.is-scrolled .nav-lang-toggle .lang-toggle) {
    background: transparent !important;
    border-color: rgb(209 213 219);
  }
  :global(#main-nav.is-scrolled .nav-lang-toggle .lang-option) {
    color: var(--color-dark);
    background: transparent !important;
    box-shadow: none !important;
  }
  :global(#main-nav.is-scrolled .nav-lang-toggle .lang-option[aria-pressed="true"]) {
    background: rgba(0, 0, 0, 0.06) !important;
    color: var(--color-primary);
  }
</style>

<script>
  const header = document.getElementById('main-header');
  const nav = document.getElementById('main-nav');
  const SCROLL_THRESHOLD = 60;
  const onScroll = () => {
    const scrolled = window.scrollY > SCROLL_THRESHOLD;
    if (header) header.classList.toggle('is-scrolled', scrolled);
    if (nav) {
      if (scrolled) {
        nav.style.backgroundColor = '';
        nav.classList.add('bg-white', 'shadow-md', 'is-scrolled');
      } else {
        nav.style.backgroundColor = 'transparent';
        nav.classList.remove('bg-white', 'shadow-md', 'is-scrolled');
      }
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Move mobile menu overlay to end of body so it's always on top (fixes About & other pages)
  const overlayEl = document.getElementById('mobile-menu-overlay');
  if (overlayEl && overlayEl.parentElement && document.body) {
    document.body.appendChild(overlayEl);
  }

  const mobileBtn = document.getElementById('mobile-menu-btn');
  const overlay = document.getElementById('mobile-menu-overlay');
  const panel = document.getElementById('mobile-menu-panel');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  const closeBtn = document.getElementById('mobile-menu-close');

  function openMobileMenu() {
    if (!overlay || !panel) return;
    document.body.style.overflow = 'hidden';
    overlay.classList.remove('opacity-0', 'pointer-events-none');
    overlay.setAttribute('aria-hidden', 'false');
    overlay.removeAttribute('inert');
    panel.classList.remove('translate-y-[-100%]');
    panel.classList.add('translate-y-0');
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    mobileBtn?.setAttribute('aria-expanded', 'true');
    mobileBtn?.setAttribute('aria-label', 'Close menu');
    if (closeBtn) {
      closeBtn.style.display = 'flex';
      closeBtn.style.visibility = 'visible';
      closeBtn.style.opacity = '1';
    }
  }

  function closeMobileMenu() {
    if (!overlay || !panel) return;
    panel.classList.remove('translate-y-0');
    panel.classList.add('translate-y-[-100%]');
    overlay.classList.add('opacity-0', 'pointer-events-none');
    overlay.setAttribute('aria-hidden', 'true');
    overlay.setAttribute('inert', '');
    document.body.style.overflow = '';
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    mobileBtn?.setAttribute('aria-expanded', 'false');
    mobileBtn?.setAttribute('aria-label', 'Open menu');
    if (closeBtn) {
      closeBtn.style.display = 'none';
    }
  }

  mobileBtn?.addEventListener('click', () => {
    const isOpen = overlay?.getAttribute('aria-hidden') === 'false';
    if (isOpen) closeMobileMenu();
    else openMobileMenu();
  });

  closeBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    e.preventDefault();
    closeMobileMenu();
  });

  overlay?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('mobile-menu-backdrop')) closeMobileMenu();
  });

  document.querySelectorAll('.mobile-menu-link').forEach(link => {
    link.addEventListener('click', closeMobileMenu);
  });

  document.getElementById('mobile-menu-logo-link')?.addEventListener('click', closeMobileMenu);

  // Mobile submenu: Quad Safari Activities accordion (closed by default)
  const activitiesToggle = document.getElementById('mobile-activities-toggle');
  const activitiesSubmenu = document.getElementById('mobile-activities-submenu');
  const activitiesChevron = document.getElementById('mobile-activities-chevron');

  activitiesToggle?.addEventListener('click', () => {
    const isOpen = activitiesToggle.getAttribute('aria-expanded') === 'true';
    if (isOpen) {
      activitiesSubmenu?.classList.remove('grid-rows-[1fr]', 'opacity-100', 'max-h-none');
      activitiesSubmenu?.classList.add('grid-rows-[0fr]', 'opacity-0', 'max-h-0');
      activitiesToggle.setAttribute('aria-expanded', 'false');
      activitiesSubmenu?.setAttribute('aria-hidden', 'true');
      activitiesChevron?.classList.remove('rotate-180');
    } else {
      activitiesSubmenu?.classList.remove('grid-rows-[0fr]', 'opacity-0', 'max-h-0');
      activitiesSubmenu?.classList.add('grid-rows-[1fr]', 'opacity-100', 'max-h-none');
      activitiesToggle.setAttribute('aria-expanded', 'true');
      activitiesSubmenu?.setAttribute('aria-hidden', 'false');
      activitiesChevron?.classList.add('rotate-180');
    }
  });

  // When opening mobile menu, reset activities submenu to closed
  const originalOpenMobileMenu = openMobileMenu;
  openMobileMenu = function () {
    originalOpenMobileMenu();
    if (activitiesSubmenu) {
      activitiesSubmenu.classList.remove('grid-rows-[1fr]', 'opacity-100', 'max-h-none');
      activitiesSubmenu.classList.add('grid-rows-[0fr]', 'opacity-0', 'max-h-0');
      activitiesToggle?.setAttribute('aria-expanded', 'false');
      activitiesSubmenu.setAttribute('aria-hidden', 'true');
      activitiesChevron?.classList.remove('rotate-180');
    }
  };
</script>
