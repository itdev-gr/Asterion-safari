---
const areas = [
  'Malia', 'Stalida', 'Chersonissos', 'Milatos', 'Sissi', 'Koutouloufari',
  'Piskopiano', 'Anissaras', 'Analipsi', 'Gouves', 'Kokkini Hani'
];
---

<section class="pickups-section pt-12 pb-20 sm:pt-16 sm:pb-24 bg-gray-50" aria-labelledby="pickups-title">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="pickups-title" class="pickups-title text-2xl md:text-3xl font-bold text-dark text-center mb-4 md:mb-6" data-i18n="pickups.sectionTitle">
      Pick up areas
    </h2>
    <p class="pickups-subtitle text-gray-600 text-center text-sm sm:text-base max-w-xl mx-auto mb-10 sm:mb-14" data-i18n="pickups.subtitle">
      We pick you up from these areas. Select your location when booking.
    </p>
    <div class="pickups-grid grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 sm:gap-4 max-w-4xl mx-auto">
      {areas.map((area) => (
        <div class="pickup-item flex items-center gap-2.5 sm:gap-3 px-4 py-3 sm:px-5 sm:py-3.5 rounded-xl bg-white border border-gray-100 shadow-sm hover:shadow-md hover:border-primary/20 transition-shadow duration-300">
          <span class="pickup-icon flex-shrink-0 w-8 h-8 sm:w-9 sm:h-9 rounded-full bg-primary/10 flex items-center justify-center" aria-hidden="true">
            <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </span>
          <span class="text-dark font-semibold text-sm sm:text-base truncate">{area}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector('.pickups-section');
  const title = document.querySelector('.pickups-title');
  const subtitle = document.querySelector('.pickups-subtitle');
  const items = document.querySelectorAll('.pickup-item');

  if (section && items.length) {
    const toAnimate = [title, subtitle, ...items].filter(Boolean);
    gsap.set(toAnimate, { opacity: 0, y: 24 });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top 85%',
        end: 'top 50%',
        toggleActions: 'play none none none',
      },
    });

    tl.to(title, { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' });
    if (subtitle) tl.to(subtitle, { opacity: 1, y: 0, duration: 0.35, ease: 'power2.out' }, '-=0.2');
    tl.to(items, {
      opacity: 1,
      y: 0,
      duration: 0.4,
      stagger: { amount: 0.35, from: 'start' },
      ease: 'power2.out',
    }, '-=0.1');
  }
</script>
