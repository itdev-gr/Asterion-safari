---
const reviews = [
  { initials: 'S', name: 'Sandra', country: 'United Kingdom', date: 'November 3, 2025', text: 'Great mix of adventure and local sights. The guides were friendly and made everyone feel safe. The quad ride was fun and a bit dusty, with beautiful views and interesting village stops. A fun and well-run experience overall.' },
  { initials: 'L', name: 'Laura', country: 'France', date: 'March 1, 2026', text: 'Perfect, a big thank you to our guide' },
  { initials: 'B', name: 'Beeke', country: 'Germany', date: 'November 1, 2025', text: 'Everything went smoothly, a great vacation experience, and the guide was very helpful. It was definitely worth it.' },
  { initials: 'M', name: 'Max', country: 'Germany', date: 'October 29, 2025', text: 'We had a great experience. The route was very scenic passing by some lovely villages in the back of the island, with some fun off-road tracks and we had the chance to try some local olive oil. All in all, a five star experience.' },
  { initials: 'M', name: 'Mat', country: 'United Kingdom', date: 'October 28, 2025', text: 'Really good way to see the local sights. Great fun, guide was excellent, he took lots of photos for us and was good fun. Quad bikes were easy to ride.' },
  { initials: 'L', name: 'Loreley', country: 'Germany', date: 'October 25, 2025', text: 'An unbelievably great tour with the best guide we could have gotten. The ride was exciting with varied stops in small villages and an olive oil factory. We also got a tour and tasting on site. The day was our best in Crete so far, and we will definitely book this activity again on our next stay. Highly recommended!!!' },
];
const maxIndex = 3; // 6 cards, 3 visible => positions 0,1,2,3
---

<section class="testimonials-carousel py-16 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl md:text-3xl font-bold text-dark text-center mb-8" data-i18n="testimonials.sectionTitle">
      Testimonials from Our Valued Clients
    </h2>

    <div class="flex flex-col md:flex-row gap-8 md:gap-10 items-start">
      <!-- Left panel -->
      <div class="w-full md:w-[220px] md:min-w-[220px] shrink-0 flex flex-col gap-3">
        <p class="font-bold text-dark text-lg">Asterion Quads</p>
        <div class="flex items-center gap-2">
          <span class="text-dark font-bold">5.0</span>
          <span class="text-primary text-lg" aria-hidden="true">★★★★★</span>
        </div>
        <p class="text-gray-600 text-sm" data-i18n="testimonials.basedOnReviews">Based on 20 reviews</p>
        <p class="text-gray-600 text-sm">
          <span data-i18n="testimonials.poweredByGoogle">powered by</span>
          <span class="inline-flex font-medium">
            <span style="color:#4285F4">G</span><span style="color:#EA4335">o</span><span style="color:#FBBC05">o</span><span style="color:#4285F4">g</span><span style="color:#34A853">l</span><span style="color:#EA4335">e</span>
          </span>
        </p>
      </div>

      <!-- Right panel: carousel -->
      <div class="flex-1 w-full md:min-w-0 overflow-hidden relative">
        <div class="relative">
          <!-- Arrow left -->
          <button
            type="button"
            class="testimonials-prev absolute left-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white shadow-md border border-gray-200 flex items-center justify-center text-dark hover:bg-gray-50 disabled:opacity-40 disabled:pointer-events-none"
            aria-label="Previous reviews"
          >
            <span class="text-xl leading-none">&lt;</span>
          </button>
          <!-- Arrow right -->
          <button
            type="button"
            class="testimonials-next absolute right-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white shadow-md border border-gray-200 flex items-center justify-center text-dark hover:bg-gray-50 disabled:opacity-40 disabled:pointer-events-none"
            aria-label="Next reviews"
          >
            <span class="text-xl leading-none">&gt;</span>
          </button>

          <!-- Track container (overflow hidden) -->
          <div class="overflow-hidden px-12">
            <div class="testimonials-track flex gap-4 transition-transform duration-300 ease-out" style="transform: translateX(0);">
              {reviews.map((r) => (
                <div class="testimonials-card flex-shrink-0 w-[280px] bg-white rounded-xl shadow-sm p-5">
                  <div class="flex items-start justify-between gap-2 mb-2">
                    <div class="flex items-center gap-3 min-w-0">
                      <div class="w-10 h-10 rounded-full bg-gray-600 flex items-center justify-center text-white font-semibold text-sm shrink-0">
                        {r.initials}
                      </div>
                      <div class="min-w-0">
                        <p class="font-bold text-dark truncate">{r.name} – {r.country}</p>
                        <p class="text-gray-500 text-xs">{r.date}</p>
                      </div>
                    </div>
                    <span class="shrink-0 text-xs font-medium" style="color:#4285F4" aria-hidden="true">G</span>
                  </div>
                  <p class="text-amber-500 text-sm mb-2" aria-hidden="true">★★★★★</p>
                  <p class="text-gray-600 text-sm leading-relaxed">{r.text}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Dots -->
        <div class="flex justify-center gap-2 mt-6">
          {[0, 1, 2, 3].map((i) => (
            <button
              type="button"
              class="testimonials-dot w-8 h-8 flex items-center justify-center"
              data-index={i}
              aria-label={`Go to slide ${i + 1}`}
            >
              <span class="w-2.5 h-2.5 rounded-full bg-gray-300 hover:bg-gray-400 transition-colors block data-[active]:bg-primary data-[active]:w-3 data-[active]:h-3"></span>
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const section = document.querySelector('.testimonials-carousel');
    if (!section) return;

    const track = section.querySelector('.testimonials-track');
    const cards = section.querySelectorAll('.testimonials-card');
    const prevBtn = section.querySelector('.testimonials-prev');
    const nextBtn = section.querySelector('.testimonials-next');
    const dots = section.querySelectorAll('.testimonials-dot');

    const maxIndex = 3;
    let currentIndex = 0;

    function getStepPx() {
      if (cards.length === 0) return 0;
      const card = cards[0];
      const style = getComputedStyle(track);
      const gap = parseFloat(style.gap) || 16;
      return card.getBoundingClientRect().width + gap;
    }

    function updateCarousel() {
      const step = getStepPx();
      track.style.transform = `translateX(-${currentIndex * step}px)`;

      if (prevBtn) {
        prevBtn.disabled = currentIndex === 0;
      }
      if (nextBtn) {
        nextBtn.disabled = currentIndex === maxIndex;
      }

      dots.forEach((dot, i) => {
        const inner = dot.querySelector('span');
      if (inner) {
        if (i === currentIndex) inner.setAttribute('data-active', '');
        else inner.removeAttribute('data-active');
      }
      });
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        currentIndex = Math.max(0, currentIndex - 1);
        updateCarousel();
      });
    }
    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        currentIndex = Math.min(maxIndex, currentIndex + 1);
        updateCarousel();
      });
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        currentIndex = i;
        updateCarousel();
      });
    });

    window.addEventListener('resize', updateCarousel);
    updateCarousel();
  })();
</script>
