---
// Χρησιμοποίησε PUBLIC_HERO_VIDEO_URL στο Vercel (ή .env) αν το βίντεο είναι σε εξωτερικό URL
const heroVideoPath = import.meta.env.PUBLIC_HERO_VIDEO_URL || '/photo/hero.mp4';
---

<section class="relative min-h-[92vh] flex items-center justify-center overflow-hidden bg-black" data-hero="video-only">
  <video
    id="hero-video"
    class="absolute inset-0 w-full h-full object-cover z-[1]"
    style="background: #000"
    poster=""
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    aria-hidden="true"
  >
    <source src={heroVideoPath} type="video/mp4" />
  </video>
  <div class="absolute inset-0 bg-black/50 z-[2]" aria-hidden="true"></div>
  <div class="relative z-10 text-center px-4">
    <h1 class="text-white text-3xl sm:text-4xl md:text-5xl font-bold mb-8" data-i18n="hero.title">
      Explore Quad Biking
    </h1>
    <a
      href="#activities"
      class="inline-block bg-primary text-white font-semibold rounded-lg px-8 py-3 hover:opacity-90 transition-opacity"
      data-i18n="hero.bookNow"
    >
      Book Now
    </a>
  </div>
</section>

<div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-12 mt-8 sm:mt-12 relative z-20 bg-transparent shadow-none">
  <div class="flex flex-col sm:flex-row flex-wrap sm:flex-nowrap justify-center items-stretch gap-6 sm:gap-8 md:gap-12 lg:gap-16 xl:gap-24">
    <div class="flex flex-col items-center text-center gap-3 sm:gap-5 flex-1 min-w-0 bg-transparent shadow-none">
      <img src="/self-driving.png" alt="" class="w-20 h-20 sm:w-28 sm:h-28 md:w-32 md:h-32 object-contain shrink-0 bg-transparent shadow-none" aria-hidden="true" />
      <p class="font-semibold text-primary text-base sm:text-xl md:text-2xl" data-i18n="hero.selfDriving">Self Driving</p>
      <p class="text-gray-600 text-sm sm:text-lg" data-i18n="hero.automaticQuads">Automatic 4x4 Quad Bikes</p>
    </div>
    <div class="flex flex-col items-center text-center gap-3 sm:gap-5 flex-1 min-w-0 bg-transparent shadow-none">
      <img src="/go-off-road.png" alt="" class="w-20 h-20 sm:w-28 sm:h-28 md:w-32 md:h-32 object-contain shrink-0 bg-transparent shadow-none" aria-hidden="true" />
      <p class="font-semibold text-primary text-base sm:text-xl md:text-2xl" data-i18n="hero.goOffRoad">Go off-road</p>
      <p class="text-gray-600 text-sm sm:text-lg" data-i18n="hero.exploreCreteOffRoad">Explore Creta off road</p>
    </div>
    <div class="flex flex-col items-center text-center gap-3 sm:gap-5 flex-1 min-w-0 bg-transparent shadow-none">
      <img src="/Free-Cancelation.png" alt="" class="w-20 h-20 sm:w-28 sm:h-28 md:w-32 md:h-32 object-contain shrink-0 bg-transparent shadow-none" aria-hidden="true" />
      <p class="font-semibold text-primary text-base sm:text-xl md:text-2xl" data-i18n="hero.freeCancelation">Free Cancelation & Refund</p>
      <p class="text-gray-600 text-sm sm:text-lg" data-i18n="hero.termsApply">Terms & Conditions apply</p>
    </div>
  </div>
</div>

<script>
  const heroVideo = document.getElementById('hero-video');
  if (heroVideo) {
    heroVideo.addEventListener('error', () => heroVideo.classList.add('hidden'));
    heroVideo.addEventListener('loadeddata', () => heroVideo.play().catch(() => {}));
    heroVideo.addEventListener('canplay', () => heroVideo.play().catch(() => {}));
  }
</script>
