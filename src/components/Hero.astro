---
---

<section class="relative min-h-[70vh] flex items-center justify-center bg-cover bg-center" style="background-image: url('https://asterionsafari.com/wp-content/uploads/2022/05/IMG-20230623-WA0002-3-1-768x513.jpg')">
  <div class="absolute inset-0 bg-black/50" aria-hidden="true"></div>
  <div class="relative z-10 text-center px-4">
    <h1 class="text-white text-3xl sm:text-4xl md:text-5xl font-bold mb-8">
      Explore Quad Biking
    </h1>
    <a
      href="#activities"
      class="inline-block bg-primary text-white font-semibold rounded-lg px-8 py-3 hover:opacity-90 transition-opacity"
    >
      Book Now
    </a>
  </div>
</section>

<div class="max-w-6xl mx-auto px-4 py-12 mt-12 relative z-20 bg-transparent shadow-none">
  <div class="flex flex-row flex-nowrap gap-8 md:gap-[12rem] lg:gap-[15rem] justify-center items-stretch">
    <div class="flex flex-col items-center text-center gap-5 bg-transparent shadow-none">
      <img src="/self-driving.png" alt="" class="w-28 h-28 md:w-32 md:h-32 object-contain shrink-0 bg-transparent shadow-none" aria-hidden="true" />
      <p class="font-semibold text-primary text-xl md:text-2xl">Self Driving</p>
      <p class="text-gray-600 text-lg">Automatic 4x4 Quad Bikes</p>
    </div>
    <div class="flex flex-col items-center text-center gap-5 bg-transparent shadow-none">
      <img src="/go-off-road.png" alt="" class="w-28 h-28 md:w-32 md:h-32 object-contain shrink-0 bg-transparent shadow-none" aria-hidden="true" />
      <p class="font-semibold text-primary text-xl md:text-2xl">Go off-road</p>
      <p class="text-gray-600 text-lg">Explore Creta off road</p>
    </div>
    <div class="flex flex-col items-center text-center gap-5 bg-transparent shadow-none">
      <img src="/Free-Cancelation.png" alt="" class="w-28 h-28 md:w-32 md:h-32 object-contain shrink-0 bg-transparent shadow-none" aria-hidden="true" />
      <p class="font-semibold text-primary text-xl md:text-2xl">Free Cancelation & Refund</p>
      <p class="text-gray-600 text-lg">Terms & Conditions apply</p>
    </div>
  </div>
</div>
