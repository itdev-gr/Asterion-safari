---
---

<section class="relative min-h-[65vh] sm:min-h-[92vh] flex items-center justify-center overflow-hidden bg-black -mt-[130px] pt-[130px] max-lg:-mt-[88px] max-lg:pt-[88px]" data-hero="video-only">
  <div class="hero-video-wrapper">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="auto"
    >
      <source
        src="/photo/aerial-view-of-atv-team-driving-slow-through-the-f-2025-12-17-03-40-13-utc.mov"
        type="video/quicktime"
      />
      <source
        src="/photo/aerial-view-of-atv-team-driving-slow-through-the-f-2025-12-17-03-40-13-utc.mov"
        type="video/mp4"
      />
    </video>
  </div>
  <div class="absolute inset-0 bg-black/50 z-[2]" aria-hidden="true"></div>
  <div class="relative z-10 text-center px-4">
    <h1 class="text-white text-3xl sm:text-4xl md:text-5xl font-bold mb-8" data-i18n="hero.title">
      Explore Quad Biking
    </h1>
    <a
      href="#activities"
      class="inline-block bg-primary text-white font-semibold rounded-lg px-8 py-3 hover:opacity-90 transition-opacity"
      data-i18n="hero.bookNow"
    >
      Book Now
    </a>
  </div>
</section>

<style>
  .hero-video-wrapper {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 0;
  }

  .hero-video-wrapper video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>

<div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-12 mt-8 sm:mt-12 relative z-20">
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-8">
    <div class="flex flex-col items-center text-center p-6 sm:p-8 rounded-xl bg-white/95 shadow-sm border border-gray-100">
      <div class="w-16 h-16 sm:w-20 sm:h-20 mb-4 flex items-center justify-center">
        <img src="/self-driving.png" alt="" class="w-full h-full object-contain" aria-hidden="true" />
      </div>
      <h3 class="font-semibold text-primary text-lg sm:text-xl mb-1" data-i18n="hero.selfDriving">Self Driving</h3>
      <p class="text-gray-600 text-sm sm:text-base" data-i18n="hero.automaticQuads">Automatic 4x4 Quad Bikes</p>
    </div>
    <div class="flex flex-col items-center text-center p-6 sm:p-8 rounded-xl bg-white/95 shadow-sm border border-gray-100">
      <div class="w-16 h-16 sm:w-20 sm:h-20 mb-4 flex items-center justify-center">
        <img src="/go-off-road.png" alt="" class="w-full h-full object-contain" aria-hidden="true" />
      </div>
      <h3 class="font-semibold text-primary text-lg sm:text-xl mb-1" data-i18n="hero.goOffRoad">Go off-road</h3>
      <p class="text-gray-600 text-sm sm:text-base" data-i18n="hero.exploreCreteOffRoad">Explore Creta off road</p>
    </div>
    <div class="flex flex-col items-center text-center p-6 sm:p-8 rounded-xl bg-white/95 shadow-sm border border-gray-100">
      <div class="w-16 h-16 sm:w-20 sm:h-20 mb-4 flex items-center justify-center">
        <img src="/Free-Cancelation.png" alt="" class="w-full h-full object-contain" aria-hidden="true" />
      </div>
      <h3 class="font-semibold text-primary text-sm sm:text-base mb-1 whitespace-nowrap" data-i18n="hero.freeCancelation">Free Cancelation & Refund</h3>
      <p class="text-gray-600 text-xs sm:text-sm" data-i18n="hero.termsApply">Terms & Conditions apply</p>
    </div>
  </div>
</div>

<script>
  const video = document.querySelector('.hero-video-wrapper video');
  if (video) {
    video.play().catch(() => {});
  }
</script>
