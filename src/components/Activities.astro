---

<section id="activities" class="py-16" style="background-color: #f8f8f8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl md:text-3xl font-bold text-dark text-center mb-10 md:mb-12">
      Explore Crete Off-Road: Quad Bike Safari Adventures
    </h2>
    <div class="grid grid-cols-1 gap-8">
      <article class="bg-white rounded-xl shadow-md overflow-hidden flex flex-col md:flex-row">
        <div class="md:w-[40%] shrink-0">
          <img
            src="https://asterionsafari.com/wp-content/uploads/2024/03/WhatsApp-Image-2023-12-28-at-13.22.46_3eefa10c-450x300.jpg"
            alt="Evening Tour"
            class="w-full h-56 md:h-full md:min-h-[220px] object-cover rounded-t-xl md:rounded-l-xl md:rounded-tr-none"
          />
        </div>
        <div class="p-5 md:p-6 flex-1 flex flex-col md:flex-row md:items-stretch gap-4">
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-dark text-lg mb-2">Off-Road Quad Safari Evening Tour with Hotel Transfer</h3>
            <p class="text-gray-500 text-sm mb-3 line-clamp-2">Discover the mountains of Crete on a guided quad biking tour. Go offroad and ride along dusty trails...</p>
            <p class="text-gray-500 text-sm flex items-center gap-1.5">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              4,5 Hours
            </p>
          </div>
          <div class="border-t md:border-t-0 md:border-l border-gray-200 pl-0 md:pl-5 flex flex-col justify-between gap-3 pt-3 md:pt-0">
            <p class="font-semibold text-dark">From €130,00</p>
            <a href="/evening-tour" class="inline-block bg-primary text-white font-medium rounded-lg px-5 py-2.5 hover:opacity-90 transition-opacity text-center w-fit">
              View details
            </a>
          </div>
        </div>
      </article>
      <article class="bg-white rounded-xl shadow-md overflow-hidden flex flex-col md:flex-row">
        <div class="md:w-[40%] shrink-0">
          <img
            src="https://asterionsafari.com/wp-content/uploads/2022/05/IMG-20230623-WA0002-3-1-450x300.jpg"
            alt="Day Tour"
            class="w-full h-56 md:h-full md:min-h-[220px] object-cover rounded-t-xl md:rounded-l-xl md:rounded-tr-none"
          />
        </div>
        <div class="p-5 md:p-6 flex-1 flex flex-col md:flex-row md:items-stretch gap-4">
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-dark text-lg mb-2">Quad Safari Off-Road Tour with Hotel Transfer</h3>
            <p class="text-gray-500 text-sm mb-3 line-clamp-2">Embark on an unforgettable guided quad tour experience and speed through the Cretan countryside. Get to know...</p>
            <p class="text-gray-500 text-sm flex items-center gap-1.5">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              4,5 Hours
            </p>
          </div>
          <div class="border-t md:border-t-0 md:border-l border-gray-200 pl-0 md:pl-5 flex flex-col justify-between gap-3 pt-3 md:pt-0">
            <p class="font-semibold text-dark">From €160,00</p>
            <a href="/day-tour" class="inline-block bg-primary text-white font-medium rounded-lg px-5 py-2.5 hover:opacity-90 transition-opacity text-center w-fit">
              View details
            </a>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
