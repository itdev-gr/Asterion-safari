---
---

<section id="activities" class="py-10 sm:py-16" style="background-color: #f8f8f8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-dark text-center mb-8 sm:mb-10 md:mb-12 px-2">
      Explore Crete Off-Road: Quad Bike Safari Adventures
    </h2>
    <div id="activities-container" class="flex flex-col gap-6 sm:gap-8">
      <!-- Populated dynamically -->
      <div class="text-center py-8 text-gray-400">Loading tours...</div>
    </div>
  </div>
</section>

<script>
  async function loadActivities() {
    let tours = null;
    const cached = sessionStorage.getItem('nav-tours');
    if (cached) {
      try {
        const parsed = JSON.parse(cached);
        if (parsed.ts && Date.now() - parsed.ts < 60000) {
          tours = parsed.data;
        }
      } catch {}
    }
    if (!tours) {
      try {
        const res = await fetch('/api/get-tours');
        tours = await res.json();
        sessionStorage.setItem('nav-tours', JSON.stringify({ data: tours, ts: Date.now() }));
      } catch { tours = []; }
    }

    const container = document.getElementById('activities-container');
    if (!container || !tours.length) return;

    tours = tours.filter((t: any) => t.title && t.cardImage && t.cardImage.startsWith('http'));

    container.innerHTML = tours.map((t: any) => `
      <article class="bg-white rounded-xl shadow-md overflow-hidden flex flex-col md:flex-row min-w-0">
        <div class="w-full md:w-[40%] shrink-0 flex-shrink-0">
          <img
            src="${t.cardImage}"
            alt="${t.shortTitle}"
            class="w-full h-48 sm:h-56 md:h-full md:min-h-[220px] object-cover rounded-t-xl md:rounded-l-xl md:rounded-tr-none"
          />
        </div>
        <div class="p-4 sm:p-5 md:p-6 flex-1 flex flex-col md:flex-row md:items-stretch gap-3 sm:gap-4 min-w-0">
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-dark text-base sm:text-lg mb-1 sm:mb-2">${t.title}</h3>
            <p class="text-gray-500 text-sm mb-2 sm:mb-3 line-clamp-2">${t.shortDescription}</p>
            <p class="text-gray-500 text-sm flex items-center gap-1.5">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              ${t.duration}
            </p>
          </div>
          <div class="border-t md:border-t-0 md:border-l border-gray-200 pl-0 md:pl-5 flex flex-row md:flex-col flex-wrap justify-between md:justify-end items-center gap-2 pt-3 md:pt-0">
            <p class="font-semibold text-dark">From \u20AC${t.price?.toLocaleString('de-DE', { minimumFractionDigits: 2 })}</p>
            <a href="/tours/${t.slug}" class="inline-block bg-primary text-white font-medium rounded-lg px-4 sm:px-5 py-2 sm:py-2.5 hover:opacity-90 transition-opacity text-center w-fit text-sm sm:text-base">
              View details
            </a>
          </div>
        </div>
      </article>
    `).join('');
  }
  loadActivities();
</script>
